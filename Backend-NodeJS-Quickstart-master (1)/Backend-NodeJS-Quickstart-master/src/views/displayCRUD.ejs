<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Danh sách người dùng — Phân quyền</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <style>
        .table-actions a {
            display: inline-block;
            margin-right: 6px;
            padding: 4px 10px;
            border-radius: 4px;
            font-size: 13px;
            text-decoration: none;
            color: #fff;
        }

        .btn-edit {
            background: #fd7e14;
        }

        .btn-delete {
            background: #dc3545;
        }
    </style>
</head>

<body class="bg-light">
    <div class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h4 class="mb-0">Danh sách người dùng</h4>
                <p class="text-muted small mb-0">Cột vai trò / chức danh hiển thị theo <code>allcode</code></p>
            </div>
            <a href="/crud" class="btn btn-primary">+ Tạo người dùng</a>
        </div>

        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-striped table-bordered mb-0">
                    <thead class="thead-light">
                        <tr>
                            <th>Email</th>
                            <th>Họ</th>
                            <th>Tên</th>
                            <th>SĐT</th>
                            <th>Vai trò</th>
                            <th>Chức danh</th>
                            <th>Địa chỉ</th>
                            <th style="min-width: 140px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% dataTable.forEach(function(row) {
                            var roleLabel = roleMap[row.roleId] || row.roleId || '—';
                            var posLabel = row.positionId ? (positionMap[row.positionId] || row.positionId) : '—';
                            var phone = row.phoneNumber || row.phonenumber || '—';
                        %>
                            <tr>
                                <td><%= row.email %></td>
                                <td><%= row.lastName %></td>
                                <td><%= row.firstName %></td>
                                <td><%= phone %></td>
                                <td><span class="badge badge-info"><%= roleLabel %></span></td>
                                <td><%= posLabel %></td>
                                <td><%= row.address || '—' %></td>
                                <td class="table-actions">
                                    <a href="/edit-crud?id=<%= row.id %>" class="btn-edit">Sửa</a>
                                    <a href="/delete-crud?id=<%= row.id %>" class="btn-delete" onclick="return confirm('Xóa người dùng này?');">Xóa</a>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</body>

</html>
